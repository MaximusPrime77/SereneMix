{
  "name": "primemix",
  "version": "1.0.0",
  "description": "PrimeMix - Premium Ambient Sound Mixer with System Tray support",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --windows"
  },
  "keywords": [
    "ambient",
    "sounds",
    "mixer",
    "relax",
    "focus",
    "sleep"
  ],
  "author": "Maximus Decimus Meridius",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.primemix.app",
    "productName": "PrimeMix",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "portable",
        "zip"
      ],
      "icon": "app_icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "tray_icon.png",
      "app_icon.png"
    ],
    "extraFiles": [
      {
        "from": "../SereneMixSound",
        "to": "PrimeMix_Data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true
  }
}
